 #if defined(WITH_AAD)
+
+/* Local PKCE patch for AVD Gov webclient redirect. */
+#include <openssl/evp.h>
+#include <openssl/rand.h>
+#include <openssl/sha.h>
+
+static char freerdp_local_pkce_verifier[128] = { 0 };
+static char freerdp_local_pkce_challenge[128] = { 0 };
+static BOOL freerdp_local_pkce_ready = FALSE;
+
+static BOOL freerdp_local_base64url(const BYTE* input, size_t input_len, char* output,
+                                    size_t output_len)
+{
+        if (!input || !output || (output_len == 0))
+                return FALSE;
+
+        const size_t b64_len = 4 * ((input_len + 2) / 3);
+        if (b64_len + 1 > INT_MAX)
+                return FALSE;
+
+        unsigned char* tmp = (unsigned char*)calloc(1, b64_len + 1);
+        if (!tmp)
+                return FALSE;
+
+        const int encoded_len = EVP_EncodeBlock(tmp, input, (int)input_len);
+        if (encoded_len < 0)
+        {
+                free(tmp);
+                return FALSE;
+        }
+
+        size_t j = 0;
+        for (int i = 0; i < encoded_len; i++)
+        {
+                char c = (char)tmp[i];
+
+                if (c == '=')
+                        break;
+
+                if (j + 1 >= output_len)
+                {
+                        free(tmp);
+                        return FALSE;
+                }
+
+                if (c == '+')
+                        c = '-';
+                else if (c == '/')
+                        c = '_';
+
+                output[j++] = c;
+        }
+
+        output[j] = '\0';
+        free(tmp);
+        return TRUE;
+}
+
+static BOOL freerdp_local_pkce_init(void)
+{
+        BYTE random_bytes[48] = { 0 };
+        BYTE digest[SHA256_DIGEST_LENGTH] = { 0 };
+
+        if (freerdp_local_pkce_ready)
+                return TRUE;
+
+        if (RAND_bytes(random_bytes, sizeof(random_bytes)) != 1)
+                return FALSE;
+
+        if (!freerdp_local_base64url(random_bytes, sizeof(random_bytes),
+                                     freerdp_local_pkce_verifier,
+                                     sizeof(freerdp_local_pkce_verifier)))
+                return FALSE;
+
+        SHA256((const BYTE*)freerdp_local_pkce_verifier,
+               strlen(freerdp_local_pkce_verifier), digest);
+
+        if (!freerdp_local_base64url(digest, sizeof(digest), freerdp_local_pkce_challenge,
+                                     sizeof(freerdp_local_pkce_challenge)))
+                return FALSE;
+
+        freerdp_local_pkce_ready = TRUE;
+        return TRUE;
+}
+
+
